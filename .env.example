# ─── Supabase ────────────────────────────────────────────────────────
# Filled AUTOMATICALLY by /setup via Supabase MCP
# You do NOT need to set these manually
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ─── Resend (email) ──────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key

# ─── Cloudflare Turnstile (bot protection) ───────────────────────────
# Test key for development — replace for production
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ─── Inngest (background jobs) ─────────────────────────────────────────
# Not needed for local dev (dev server auto-connects)
# Get from: https://app.inngest.com → Manage → Signing Keys / Event Keys
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ─── PostHog (analytics) ─────────────────────────────────────────────
# Get from: https://us.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Vercel Blob (image storage — optional) ─────────────────────────
# If set, image uploads use Vercel Blob (edge CDN, fast).
# If empty, falls back to Supabase Storage automatically.
# Get from: vercel blob create <store-name> → copy token
# BLOB_READ_WRITE_TOKEN=

# ─── Sentry (optional — error tracking) ──────────────────────────────
# Get from: https://sentry.io → Settings → Auth Tokens
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Framework Instance ID (set locally — do not commit)
FRAMEWORK_INSTANCE_ID=

# Applyfast integrations
RESEND_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
JSEARCH_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_AUTH_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
